<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.tradevision.controllers.RegisterController"
           prefHeight="600.0" prefWidth="1000.0">
    
    <VBox alignment="CENTER" maxWidth="400" maxHeight="500" spacing="15" styleClass="auth-container">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>
        
        <Label text="Create Account" styleClass="title-label" />
        <Label text="Join TradeVision Pro today." styleClass="subtitle-label" />
        
        <VBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Username" />
            <TextField fx:id="usernameField" promptText="Choose a username" prefHeight="40"/>
        </VBox>
        
        <VBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Email Address" />
            <TextField fx:id="emailField" promptText="name@example.com" prefHeight="40"/>
        </VBox>
        
        <VBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Password" />
            <PasswordField fx:id="passwordField" promptText="••••••••" prefHeight="40"/>
        </VBox>
        
        <Label fx:id="errorLabel" text="" textFill="#ef4444" visible="false" />
        
        <Button text="Sign Up" fx:id="registerButton" onAction="#handleRegister" prefWidth="320" prefHeight="45" />
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?" styleClass="subtitle-label" />
            <Hyperlink text="Sign in" onAction="#goToLogin" />
        </HBox>
    </VBox>
</StackPane>
